---
import HomePage from "@/templates/HomePage.astro";
import { getLangFromParam, getPagePath, languages } from "@/data/i18n";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = getLangFromParam(Astro.params.lang);
---

<HomePage lang={lang} canonicalPath={getPagePath(lang, "home")} />
