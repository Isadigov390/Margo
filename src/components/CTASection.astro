---
import ContactButtons from "@/components/ContactButtons.astro";
import { t, type Lang } from "@/data/i18n";

interface Props {
  lang: Lang;
  title?: string;
  text?: string;
}

const lang = Astro.props.lang;
const copy = t(lang);
const {
  title = copy.cta.title,
  text = copy.cta.text,
} = Astro.props;
---

<section class="bg-espresso text-ivory">
  <div class="container-pad grid gap-8 py-14 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-champagne">{copy.cta.eyebrow}</p>
      <h2 class="mt-3 max-w-2xl font-serif text-[clamp(2.25rem,9vw,3rem)] font-semibold leading-tight">{title}</h2>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-ivory/72 md:text-base">{text}</p>
    </div>
    <ContactButtons lang={lang} compact />
  </div>
</section>
