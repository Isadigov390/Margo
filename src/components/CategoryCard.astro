---
interface Props {
  title: string;
  text: string;
  image: string;
  alt: string;
}

const { title, text, image, alt } = Astro.props;
---

<article class="group overflow-hidden rounded-2xl border border-espresso/10 bg-white/62 shadow-sm transition hover:-translate-y-1 hover:shadow-xl hover:shadow-espresso/10">
  <img class="aspect-[4/5] w-full object-cover" src={image} alt={alt} width="640" height="800" loading="lazy" decoding="async" />
  <div class="p-5">
    <h3 class="font-serif text-2xl font-semibold text-ink">{title}</h3>
    <p class="mt-2 text-sm leading-6 text-espresso/68">{text}</p>
  </div>
</article>
