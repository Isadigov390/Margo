---
import Icon from "@/components/Icon.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import ProductCard from "@/components/ProductCard.astro";
import CTASection from "@/components/CTASection.astro";
import { getWhatsappLink, site } from "@/data/site";
import { getPagePath, t, type Lang } from "@/data/i18n";
import {
  featuredProducts,
  getProductCategory,
  getProductTitle,
  instagramPreviewProducts,
  products,
} from "@/data/products";

interface Props {
  lang: Lang;
  canonicalPath: string;
}

const { lang, canonicalPath } = Astro.props;
const copy = t(lang);
---

<BaseLayout
  lang={lang}
  page="home"
  canonicalPath={canonicalPath}
  title={copy.seo.homeTitle}
  description={copy.seo.homeDescription}
  image="/images/products/noir-ivory-pleated-mini-dress-duo.jpg"
>
  <Hero lang={lang} />

  <section class="section-pad bg-ivory">
    <div class="container-pad">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-rose">{copy.home.featuredEyebrow}</p>
          <h2 class="mt-3 font-serif text-[clamp(2.4rem,8vw,4.4rem)] font-semibold leading-[0.98] text-ink">
            {copy.home.featuredTitle}
          </h2>
        </div>
        <a class="focus-ring inline-flex min-h-12 items-center justify-center rounded-full border border-espresso/15 bg-cream/70 px-5 text-sm font-bold text-ink transition hover:border-champagne hover:bg-champagne/20" href={getPagePath(lang, "collection")}>
          {copy.buttons.collection}
        </a>
      </div>
      <div class="mt-10 grid gap-5 xl:grid-cols-2">
        {featuredProducts.map((product, index) => <ProductCard product={product} lang={lang} priority={index === 0} large />)}
      </div>
    </div>
  </section>

  <section class="section-pad bg-cream/70">
    <div class="container-pad grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-sage">{copy.home.aboutEyebrow}</p>
        <h2 class="mt-3 font-serif text-[clamp(2.35rem,8vw,4rem)] font-semibold leading-tight text-ink">
          {copy.home.aboutTitle}
        </h2>
        <p class="mt-5 text-base leading-8 text-espresso/74">
          {copy.home.aboutText}
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {products.slice(0, 4).map((product) => (
          <a href={product.instagramUrl} target="_blank" rel="noopener noreferrer" class="focus-ring group block overflow-hidden rounded-[1.2rem] bg-ivory shadow-lg shadow-espresso/8">
            <img
              class="aspect-[4/5] w-full object-cover transition duration-500 group-hover:scale-[1.04]"
              src={product.image}
              alt={`${getProductTitle(product, lang)} - Margo Boutique`}
              width={product.width}
              height={product.height}
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-ivory">
    <div class="container-pad">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-rose">{copy.home.feedEyebrow}</p>
        <h2 class="mt-3 font-serif text-[clamp(2.4rem,8vw,4.4rem)] font-semibold leading-[0.98] text-ink">
          {copy.home.feedTitle}
        </h2>
      </div>
      <div class="mt-10 columns-1 gap-5 sm:columns-2 lg:columns-3">
        {
          products.map((product, index) => (
            <a
              href={product.instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              class:list={["focus-ring group mb-5 block break-inside-avoid overflow-hidden rounded-[1.35rem] bg-ivory shadow-lg shadow-espresso/8", index % 3 === 1 && "lg:mt-10"]}
            >
              <img
                class="w-full object-cover transition duration-500 group-hover:scale-[1.035]"
                src={product.image}
                alt={`${getProductTitle(product, lang)} - Margo Boutique feed`}
                width={product.width}
                height={product.height}
                loading="lazy"
                decoding="async"
              />
              <div class="p-4">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-rose">{getProductCategory(product, lang)}</p>
                <p class="mt-2 font-serif text-xl font-semibold text-ink">{getProductTitle(product, lang)}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-pad bg-cream/70">
    <div class="container-pad">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-sage">{copy.home.instagramEyebrow}</p>
          <h2 class="mt-3 font-serif text-[clamp(2.35rem,8vw,4rem)] font-semibold leading-tight text-ink">
            {copy.home.instagramTitle}
          </h2>
          <p class="mt-4 text-base leading-8 text-espresso/74">
            {copy.home.instagramText}
          </p>
        </div>
        <a class="focus-ring inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-ink px-6 text-center text-sm font-bold text-ivory transition hover:bg-espresso" href={site.instagram} target="_blank" rel="noopener noreferrer">
          <Icon name="instagram" class="h-4 w-4" /> {copy.home.instagramButton}
        </a>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {instagramPreviewProducts.map((product) => (
          <a href={product.instagramUrl} target="_blank" rel="noopener noreferrer" class="focus-ring group block overflow-hidden rounded-[1.35rem] bg-ivory shadow-lg shadow-espresso/8">
            <img
              class="aspect-[3/4] w-full object-cover transition duration-500 group-hover:scale-[1.035]"
              src={product.image}
              alt={`${getProductTitle(product, lang)} Instagram`}
              width={product.width}
              height={product.height}
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-ivory">
    <div class="container-pad grid gap-8 rounded-[1.6rem] border border-espresso/10 bg-cream/45 p-6 shadow-xl shadow-espresso/8 md:p-10 lg:grid-cols-[1fr_auto] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-sage">{copy.footer.contact}</p>
        <h2 class="mt-3 font-serif text-[clamp(2.25rem,8vw,3.4rem)] font-semibold leading-tight text-ink">{copy.home.contactTitle}</h2>
        <p class="mt-4 max-w-2xl text-base leading-8 text-espresso/74">
          {copy.home.contactText}
        </p>
      </div>
      <div class="grid gap-3 sm:flex sm:flex-wrap">
        <a class="focus-ring inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-ink px-6 text-sm font-bold text-ivory transition hover:bg-espresso" href={getWhatsappLink(lang)} target="_blank" rel="noopener noreferrer">
          <Icon name="whatsapp" class="h-4 w-4" /> WhatsApp
        </a>
        <a class="focus-ring inline-flex min-h-12 items-center justify-center rounded-full border border-espresso/15 px-6 text-sm font-bold text-ink transition hover:border-champagne hover:bg-champagne/20" href={site.maps} target="_blank" rel="noopener noreferrer">
          {copy.buttons.directions}
        </a>
      </div>
    </div>
  </section>

  <CTASection lang={lang} title={copy.home.ctaTitle} text={copy.home.ctaText} />
</BaseLayout>
