---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CTASection from "@/components/CTASection.astro";
import { t, type Lang } from "@/data/i18n";
import { getProductTitle, products } from "@/data/products";

interface Props {
  lang: Lang;
  canonicalPath: string;
}

const { lang, canonicalPath } = Astro.props;
const copy = t(lang);
---

<BaseLayout
  lang={lang}
  page="collection"
  canonicalPath={canonicalPath}
  title={copy.seo.collectionTitle}
  description={copy.seo.homeDescription}
  image="/images/products/noir-ivory-pleated-mini-dress-duo.jpg"
>
  <section class="bg-ivory">
    <div class="container-pad grid gap-8 py-12 md:py-16 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <p class="text-xs font-bold uppercase leading-6 tracking-[0.22em] text-rose sm:text-sm">{copy.collection.eyebrow}</p>
        <h1 class="mt-4 max-w-4xl font-serif text-[clamp(3rem,11vw,5.8rem)] font-semibold leading-[0.96] tracking-normal text-ink">
          {copy.collection.title}
        </h1>
      </div>
      <p class="max-w-xl text-base leading-8 text-espresso/74 lg:justify-self-end">
        {copy.collection.text}
      </p>
    </div>
  </section>

  <section class="section-pad bg-cream/70 pt-0">
    <div class="container-pad grid gap-5 xl:grid-cols-2">
      {products.map((product, index) => <ProductCard product={product} lang={lang} priority={index < 2} />)}
    </div>
  </section>

  <section class="section-pad bg-ivory">
    <div class="container-pad">
      <div class="max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-sage">{copy.collection.feedEyebrow}</p>
        <h2 class="mt-3 font-serif text-[clamp(2.35rem,8vw,4rem)] font-semibold leading-tight text-ink">
          {copy.collection.feedTitle}
        </h2>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {products.map((product) => (
          <a href={product.instagramUrl} target="_blank" rel="noopener noreferrer" class="focus-ring group block overflow-hidden rounded-[1.2rem] bg-ivory shadow-md shadow-espresso/8">
            <img
              class="aspect-[4/5] w-full object-cover transition duration-500 group-hover:scale-[1.035]"
              src={product.image}
              alt={`${getProductTitle(product, lang)} - Instagram`}
              width={product.width}
              height={product.height}
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection lang={lang} title={copy.collection.ctaTitle} text={copy.collection.ctaText} />
</BaseLayout>
