---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { contactLinks, site } from "@/data/site";
import { getDefaultPagePath, getPagePath, languages, t, type Lang, type PageKey } from "@/data/i18n";
import { absoluteUrl, withBase } from "@/data/urls";

interface Props {
  lang?: Lang;
  page?: PageKey;
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
}

const {
  lang = "az",
  page = "home",
  title = t(lang).seo.homeTitle,
  description = t(lang).seo.homeDescription,
  canonicalPath = "/",
  image = "/images/products/noir-ivory-pleated-mini-dress-duo.jpg",
} = Astro.props;

const canonical = absoluteUrl(canonicalPath);
const ogImage = absoluteUrl(image);
const alternates = languages.map((language) => ({
  lang: language.locale,
  href: absoluteUrl(getPagePath(language.code, page)),
}));
const preloadedHeroImage = withBase("/images/products/noir-ivory-pleated-mini-dress-duo.jpg");
const localBusiness = {
  "@context": "https://schema.org",
  "@type": "ClothingStore",
  name: site.name,
  description,
  image: ogImage,
  telephone: site.phoneDisplay,
  url: site.url,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Sarayevo Street 162C / 162-168",
    addressLocality: "Baku",
    addressCountry: "AZ",
  },
  openingHours: "Mo-Su 10:00-21:00",
  sameAs: [site.instagram],
  hasMap: contactLinks.maps,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />)}
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(getDefaultPagePath(page))} />
    <meta name="theme-color" content="#fffaf1" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preload" as="image" href={preloadedHeroImage} imagesrcset={preloadedHeroImage} />
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("margo-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.dataset.theme = saved || preferred;
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
  </head>
  <body class="min-h-screen text-ink antialiased">
    <Header lang={lang} page={page} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <script is:inline>
      document.addEventListener("click", (event) => {
        const button = event.target.closest("[data-theme-choice]");
        if (!button) return;
        const theme = button.getAttribute("data-theme-choice");
        document.documentElement.dataset.theme = theme;
        localStorage.setItem("margo-theme", theme);
      });
    </script>
  </body>
</html>
